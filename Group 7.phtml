    <!-- REGISTRATION FORM -->

    <form>

        <h2 style="text-align:center;">Registration Form</h2>


        <fieldset>

            <legend><strong>Personal Information</strong></legend>

            <label>Full Name</label>

            <input type="text" placeholder="Please Enter your Full Name" required>


            <label>Email</label>

            <input type="Email" placeholder="Please Enter your Email" required>


            <label>Password</label>

            <input type="text" placeholder="Please Enter your Password" required>


            <label>Birthdate</label>

            <input type="MM/DD/YY" required>


            <label>Age</label>

            <input type="number" name="age" max="100" required>

        </fieldset>


        <hr>


        <fieldset>

            <legend><strong>Additional Information</strong></legend>


            <label>Gender</label><br>

            <input type="radio" name="gender"> Female

